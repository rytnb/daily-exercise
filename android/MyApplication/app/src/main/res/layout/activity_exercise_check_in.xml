<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- 顶部标题栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#E8F5E9"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="20dp">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#2E7D32"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"/>

        <!-- 页面标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="运动打卡"
            android:textColor="#2E7D32"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerInParent="true"/>

    </RelativeLayout>

    <!-- 主要内容区域（可滚动） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 运动信息卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFBF0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 运动项目选择 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="运动项目"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <Spinner
                            android:id="@+id/sp_sport_type"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp"/>
                    </androidx.cardview.widget.CardView>

                    <!-- 开始时间 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="开始时间"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/et_start_time"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="请输入开始时间"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:background="@null"
                            android:padding="12dp"/>
                    </androidx.cardview.widget.CardView>

                    <!-- 结束时间 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="结束时间"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/et_end_time"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="请输入结束时间"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:background="@null"
                            android:padding="12dp"/>
                    </androidx.cardview.widget.CardView>

                    <!-- 运动时长 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="运动时长（分钟）"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/et_duration"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="请输入运动时长"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:inputType="number"
                            android:background="@null"
                            android:padding="12dp"/>
                    </androidx.cardview.widget.CardView>

                    <!-- 运动量 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="运动量（如：跑步距离/公里）"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/et_exercise_amount"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="请输入运动量"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:inputType="numberDecimal"
                            android:background="@null"
                            android:padding="12dp"/>
                    </androidx.cardview.widget.CardView>

                    <!-- 卡路里消耗 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="卡路里消耗（kcal）"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/et_calorie"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="请输入卡路里消耗"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:inputType="numberDecimal"
                            android:background="@null"
                            android:padding="12dp"/>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 提示信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请准确填写运动信息，系统将自动保存您的打卡记录"
                android:textColor="#666666"
                android:textSize="12sp"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- 底部开始按钮 -->
    <Button
        android:id="@+id/btn_finish"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="完成打卡"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/green_gradient_bg"
        android:layout_marginTop="16dp"/>

</LinearLayout>
