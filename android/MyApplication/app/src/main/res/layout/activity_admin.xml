<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#E8F5E9"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/circle_green_bg"
            android:src="@drawable/ic_user_avatar"
            android:scaleType="centerInside"
            android:layout_marginRight="16dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="管理员ID:"
                android:textSize="14sp"
                android:textColor="#666666"/>

            <TextView
                android:id="@+id/tv_admin_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADM20231127001"
                android:textSize="18sp"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tv_admin_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="系统管理员"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tv_admin_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="系统管理员"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="管理功能"
        android:textSize="18sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:padding="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:weightSum="2">

        <LinearLayout
            android:id="@+id/ll_plan_review"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:background="@drawable/green_stroke_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginRight="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="训练计划审核"
                android:textSize="16sp"
                android:textColor="#FF8C00"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="待审核: 12条"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_post_review"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:background="@drawable/green_stroke_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginLeft="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="主题帖审核"
                android:textSize="16sp"
                android:textColor="#FF8C00"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="待审核: 8条"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>

    </LinearLayout>